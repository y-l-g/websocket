{
  "name": "pogo/websocket",
  "description": "Pogo WebSocket Driver",
  "autoload": {
    "psr-4": {
      "Pogo\\WebSocket\\": "lib/src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Pogo\\WebSocket\\ServiceProvider"
      ]
    }
  },
  "require": {
    "laravel/octane": "^2.17.3",
    "pusher/pusher-php-server": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^2.0",
    "mockery/mockery": "^1.0"
  }
}

{
  "name": "pogo/websocket",
  "description": "Pogo WebSocket Driver",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Pogo\\WebSocket\\": "lib/src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Pogo\\WebSocket\\ServiceProvider"
      ]
    }
  },
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0 || ^12.0 || ^13.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^2.2.3",
    "mockery/mockery": "^1.0"
  }
}
